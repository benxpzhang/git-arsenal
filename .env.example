# ── Qdrant ──
QDRANT_URL=http://localhost:6333

# ── PostgreSQL ──
POSTGRES_USER=arsenal
POSTGRES_PASSWORD=arsenal
POSTGRES_DB=git_arsenal
DATABASE_URL=postgresql+asyncpg://arsenal:arsenal@localhost:5432/git_arsenal

# ── Embedding (DashScope) ──
EMBED_API_KEY=
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBED_MODEL=text-embedding-v4
EMBED_TIMEOUT=10
EMBED_MAX_RETRIES=2

# ── LLM (for HyDE, e.g. GLM-4-Flash free tier) ──
LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-flash
LLM_TIMEOUT=10

# ── JWT ──
JWT_SECRET=change-me-in-production
JWT_EXPIRE_DAYS=7

# ── Quota ──
ANON_DAILY_QUOTA=20

# ── Server ──
API_HOST=0.0.0.0
API_PORT=8003

# ── CORS (comma-separated origins) ──
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Kode-Agent ACP Bridge ──
# Path to Kode-Agent dist/index.js (absolute path)
KODE_ACP_PATH=
# Git Arsenal project root (for cwd and MCP server path resolution)
GIT_ARSENAL_ROOT=
# Backend API URL (for MCP server to call)
ARSENAL_API_URL=http://localhost:8003
